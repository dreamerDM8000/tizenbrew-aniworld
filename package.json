{
  "name": "@dreamerdm8000/tizenbrew-aniworld",
  "appName": "AniWorld",
  "version": "1.0.14",
  "description": "TizenBrew Modul für AniWorld auf Samsung Tizen TVs",
  "packageType": "mods",
  "type": "module",
  "websiteURL": "https://aniworld.to",
  "main": "dist/userScript.js",
  "serviceFile": "service/service.js",
  "keys": [
    "MediaPlayPause",
    "MediaPlay",
    "MediaPause",
    "MediaStop",
    "MediaFastForward",
    "MediaRewind",
    "MediaTrackNext",
    "MediaTrackPrevious"
  ],
  "author": "dreamerDM8000",
  "license": "MIT",
  "keywords": [
    "tizenbrew",
    "tizen",
    "samsung",
    "tv",
    "aniworld",
    "anime"
  ],
  "repository": {
    "url": "https://github.com/dreamerDM8000/tizenbrew-aniworld"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c mods/rollup.config.js"
  },
  "devDependencies": {
    "rollup": "^4.60.1"
  }
}
